<!doctype html>
<html lang="__TOKOLOGY_LANG__">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>tokology</title>
<style>
@font-face{font-family:'IBM Plex Mono';font-weight:400;font-display:swap;src:url(data:font/woff2;base64,__TOKOLOGY_FONT_400__) format('woff2');}
@font-face{font-family:'IBM Plex Mono';font-weight:600;font-display:swap;src:url(data:font/woff2;base64,__TOKOLOGY_FONT_600__) format('woff2');}
@font-face{font-family:'IBM Plex Mono';font-weight:700;font-display:swap;src:url(data:font/woff2;base64,__TOKOLOGY_FONT_700__) format('woff2');}
:root{--bg:#f4f2ea;--panel:#ffffff;--line:rgba(0,0,0,.10);--ink:#1c1b22;--dim:#76747e;--cell:rgba(0,0,0,.07);--accent:#e0890a;}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'IBM Plex Mono','PingFang SC',ui-monospace,monospace;background:var(--bg);color:var(--ink);
  line-height:1.4;-webkit-font-smoothing:antialiased;padding:44px 20px 32px;display:flex;justify-content:center}
.wrap{width:100%;max-width:1040px;position:relative;animation:fade .6s ease both}
.wrap::before{content:"";position:fixed;top:-12%;right:-8%;width:46%;height:46%;border-radius:50%;
  background:radial-gradient(circle,rgba(224,137,10,.09),transparent 70%);pointer-events:none}
.wrap::after{content:"";position:fixed;bottom:-14%;left:-10%;width:44%;height:44%;border-radius:50%;
  background:radial-gradient(circle,rgba(120,120,160,.05),transparent 70%);pointer-events:none}
@keyframes fade{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
.brand{margin-bottom:30px;position:relative}
.brand h1{font-size:clamp(2.6rem,9vw,5.4rem);font-weight:700;letter-spacing:-.03em;line-height:.9}
.brand .yr{font-size:clamp(1rem,3.2vw,1.5rem);color:var(--dim);font-weight:600;margin-top:10px;letter-spacing:.02em}
.brand .yr b{color:var(--accent);font-weight:700}
.grid3{display:grid;grid-template-columns:1fr 1fr 1.2fr;gap:16px;margin-bottom:16px}
.panel{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:22px 24px;box-shadow:0 1px 2px rgba(0,0,0,.05)}
.lab{font-size:12px;letter-spacing:.13em;text-transform:uppercase;color:var(--dim)}
.big{font-size:clamp(1.7rem,3.6vw,2.5rem);font-weight:700;line-height:1.05;margin-top:8px}
.med{font-size:1.05rem;color:var(--ink);margin-top:9px}
.weekly{display:flex;align-items:flex-end;gap:7px;height:84px;margin-top:14px}
.weekly .b{flex:1;display:flex;flex-direction:column;justify-content:flex-end;align-items:center;gap:7px;height:100%}
.weekly .b .bar{width:100%;background:var(--cell);border-radius:5px;min-height:5px}
.weekly .b.pk .bar{background:var(--accent)}
.weekly .b .d{font-size:11px;color:var(--dim)}
.weekly .b.pk .d{color:var(--accent)}
.act{margin:18px 2px 16px}
.act .hd{font-size:12px;letter-spacing:.13em;text-transform:uppercase;color:var(--dim);margin-bottom:12px}
.hmwrap{position:relative;overflow-x:auto}
.months{position:relative;height:16px;margin-bottom:5px}
.months span{position:absolute;font-size:11px;color:var(--dim);top:0}
.hm{display:flex;gap:3px}
.hm .wk{display:flex;flex-direction:column;gap:3px}
.hm i{width:13px;height:13px;border-radius:3px;background:var(--cell)}
.legend{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--dim);margin-top:12px}
.legend i{width:12px;height:12px;border-radius:3px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.rank{display:flex;align-items:center;gap:14px;padding:9px 0;font-size:14px}
.rank .n{color:var(--accent);font-weight:700;width:14px}
.rank .nm{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.rank .vl{color:var(--dim)}
.tiles{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.tiles .panel{text-align:center;padding:20px 14px}
.tiles .big{font-size:clamp(1.5rem,3.4vw,2.2rem);margin-top:7px}
.ft{text-align:center;color:var(--dim);font-size:12px;margin-top:24px;line-height:1.8}
.ft b{color:var(--accent);font-weight:600}
@media(max-width:680px){.grid3{grid-template-columns:1fr}.grid2{grid-template-columns:1fr}.tiles{grid-template-columns:1fr 1fr}}
</style>
</head>
<body>
<div class="wrap" id="app"></div>
<script id="data" type="application/json">__TOKOLOGY_DATA__</script>
<script>
const LANG="__TOKOLOGY_LANG__";
const D=JSON.parse(document.getElementById('data').textContent);
const compact=n=>new Intl.NumberFormat('en-US',{notation:'compact',maximumFractionDigits:1}).format(n||0);
const money=n=>'$'+Math.round(n||0).toLocaleString('en-US');
const intf=n=>Math.round(n||0).toLocaleString('en-US');
const esc=s=>String(s).replace(/[&<>]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]));
const t=D.totals,rh=D.rhythm;
const ZH=LANG==='zh';
const MON=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const WD=ZH?['日','一','二','三','四','五','六']:['S','M','T','W','T','F','S'];
const WDF=ZH?['周日','周一','周二','周三','周四','周五','周六']:['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const S=ZH?{started:'开始于',active:'最活跃的一天',weekly:'星期分布',activity:'活跃热力图',less:'少',more:'多',
  models:'模型排行榜 · 按用量',tools:'工具版图 · 按花费',sessions:'sessions',messages:'消息轮次',tokens:'总 tokens',
  activeDays:'活跃天数',streak:'最长连续',cost:'估算花费',unpriced:'未计价',pers:'年度人格',
  daysAgo:n=>n+' 天前',days:n=>n+' 天',sub:n=>'wrapped <b>2026</b> · 跨 '+n+' 个工具的一年',
  foot:(u,c)=>u+' 条未计价 · 缓存占 '+c+'% · 花费按 API 价折算 · generated locally — 数据从未离开本机'}:
  {started:'started',active:'most active day',weekly:'weekly',activity:'activity',less:'less',more:'more',
  models:'top models · by usage',tools:'top tools · by cost',sessions:'sessions',messages:'messages',tokens:'total tokens',
  activeDays:'active days',streak:'longest streak',cost:'est. cost',unpriced:'unpriced',pers:'your persona',
  daysAgo:n=>n+' days ago',days:n=>n+'d',sub:n=>'wrapped <b>2026</b> · '+n+' tools, one year',
  foot:(u,c)=>u+' unpriced · '+c+'% cache · API-equivalent estimate · generated locally — your data never left this machine'};
const P=ZH?{night_owl:'夜猫子',token_whale:'Token 鲸鱼',cache_miser:'缓存抠门大师',polyglot:'多栖玩家',steady:'稳健玩家'}:
  {night_owl:'Night Owl',token_whale:'Token Whale',cache_miser:'Cache Miser',polyglot:'Polyglot',steady:'Steady'};
const toolName={claude_code:'Claude Code',codex:'Codex',gemini:'Gemini',opencode:'OpenCode',copilot:'Copilot'};
const fmtDate=dt=>ZH?(dt.getMonth()+1)+'月'+dt.getDate()+'日':MON[dt.getMonth()]+' '+dt.getDate();

function ranks(rows,labelFn,valFn){
  return rows.map((r,i)=>`<div class="rank"><span class="n">${i+1}</span><span class="nm">${esc(labelFn(r))}</span><span class="vl">${valFn(r)}</span></div>`).join('');
}
function weekly(arr){
  const max=Math.max(...arr,1),pk=arr.indexOf(Math.max(...arr));
  return arr.map((v,i)=>`<div class="b${i===pk?' pk':''}"><div class="bar" style="height:${Math.max(v/max*100,6)}%"></div><div class="d">${WD[i]}</div></div>`).join('');
}
function activity(arr){
  if(!arr.length)return'';
  const map=new Map(arr.map(d=>[d.date,d.count]));
  const ymd=d=>`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  const first=new Date(arr[0].date+'T00:00:00'),last=new Date(arr[arr.length-1].date+'T00:00:00');
  const start=new Date(first);start.setDate(start.getDate()-start.getDay());
  const max=Math.max(...arr.map(d=>d.count),1),lmax=Math.log(max+1);
  const weeks=[];let cur=new Date(start);
  while(cur<=last){let cells='',m=cur.getMonth();
    for(let r=0;r<7;r++){let bg='transparent';
      if(cur>=first&&cur<=last){const c=map.get(ymd(cur))||0;
        if(c===0)bg='var(--cell)';else{const a=Math.round((0.2+Math.log(c+1)/lmax*0.8)*100);bg=`color-mix(in srgb,var(--accent) ${a}%,transparent)`;}}
      cells+=`<i style="background:${bg}"></i>`;cur.setDate(cur.getDate()+1);}
    weeks.push({m,html:`<div class="wk">${cells}</div>`});}
  let labels=[],lm=-1;weeks.forEach((w,i)=>{if(w.m!==lm){lm=w.m;const x=i*16;
    if(labels.length&&x-labels[labels.length-1].x<24)labels[labels.length-1]={x,m:w.m};else labels.push({x,m:w.m});}});
  const months=labels.map(l=>`<span style="left:${l.x}px">${MON[l.m]}</span>`).join('');
  return `<div class="months">${months}</div><div class="hm">${weeks.map(w=>w.html).join('')}</div>`;
}

const start=t.span?new Date(t.span.start+'T00:00:00'):null;
const daysAgo=start?Math.round((Date.now()-start)/864e5):0;
const bz=rh.busiest_day?new Date(rh.busiest_day.date+'T00:00:00'):null;
const tools=D.tool_breakdown.map(x=>({...x,label:toolName[x.tool]||x.tool}));
const models=D.model_leaderboard.slice(0,5);
const tags=(D.personality.tags||[]);
const persTitle=tags.length?tags.map(k=>P[k]||k).join(' · '):P.steady;
const cachePct=t.tokens?Math.round(D.cache.read_tokens/t.tokens*100):0;

document.getElementById('app').innerHTML=`
<div class="brand"><h1>tokology</h1><div class="yr">${S.sub(tools.length)}</div></div>

<div class="grid3">
  <div class="panel"><div class="lab">${S.started}</div><div class="med">${t.span?t.span.start:'—'}</div><div class="big">${S.daysAgo(daysAgo)}</div></div>
  <div class="panel"><div class="lab">${S.active}</div><div class="med">${bz?WDF[bz.getDay()]:'—'}</div><div class="big">${bz?fmtDate(bz):'—'}</div></div>
  <div class="panel"><div class="lab">${S.weekly}</div><div class="weekly">${weekly(D.weekday)}</div></div>
</div>

<div class="act">
  <div class="hd">${S.activity}</div>
  <div class="hmwrap">${activity(D.heatmap)}</div>
  <div class="legend">${S.less} <i style="background:var(--cell)"></i><i style="background:color-mix(in srgb,var(--accent) 35%,transparent)"></i><i style="background:color-mix(in srgb,var(--accent) 65%,transparent)"></i><i style="background:var(--accent)"></i> ${S.more}</div>
</div>

<div class="grid2">
  <div class="panel"><div class="lab" style="margin-bottom:6px">${S.models}</div>
    ${ranks(models,x=>x.model,x=>x.priced?money(x.cost_usd):S.unpriced)}</div>
  <div class="panel"><div class="lab" style="margin-bottom:6px">${S.tools}</div>
    ${ranks(tools,x=>x.label,x=>money(x.cost_usd))}</div>
</div>

<div class="tiles">
  <div class="panel"><div class="lab">${S.sessions}</div><div class="big">${compact(t.sessions)}</div></div>
  <div class="panel"><div class="lab">${S.messages}</div><div class="big">${compact(t.messages)}</div></div>
  <div class="panel"><div class="lab">${S.tokens}</div><div class="big">${compact(t.tokens)}</div></div>
  <div class="panel"><div class="lab">${S.activeDays}</div><div class="big">${t.active_days}</div></div>
  <div class="panel"><div class="lab">${S.streak}</div><div class="big">${S.days(rh.longest_streak)}</div></div>
  <div class="panel"><div class="lab">${S.cost}</div><div class="big">${money(t.cost_usd)}</div></div>
</div>

<div class="ft">${S.pers} · <b>${esc(persTitle)}</b><br>${S.foot(intf(t.unpriced_sessions),cachePct)}</div>`;
// true content height (viewport-independent) so the PNG export crops exactly
const _w=document.getElementById('app').getBoundingClientRect();
document.documentElement.setAttribute('data-h', String(Math.ceil(_w.height)+44+32));
</script>
</body>
</html>
